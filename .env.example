# Copy to .env.local and fill in. .env.local is gitignored.

# --- Email (Resend — https://resend.com) ---
# Powers the contact form and newsletter signup.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=you@example.com
# Optional: collect newsletter subscribers into a Resend Audience.
RESEND_AUDIENCE_ID=
# Optional: custom verified sender (defaults to onboarding@resend.dev,
# which can only deliver to your own Resend account email until you verify a domain).
# CONTACT_FROM=isa23 hub <hello@yourdomain.com>

# --- Private links ---
# Passcode required to unlock the gated links. CHANGE THIS.
UNLOCK_PASSCODE=change-me

# Where each gated link actually goes (kept server-side, out of the client bundle).
LINK_INSTAGRAM=https://www.instagram.com/astrayama
LINK_PROJECTS=https://devpost.com/isabiiil
LINK_PERSONAL_SITE=https://isabel-abonitalla.vercel.app/
